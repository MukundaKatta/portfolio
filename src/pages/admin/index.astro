---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin Dashboard" description="Site administration dashboard.">
  <div class="container-wide py-12 sm:py-20">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Admin Dashboard</h1>
      <p class="text-slate-600 dark:text-slate-400">Manage your portfolio content.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Posts -->
      <a href="/admin/posts" class="card p-6 hover:border-brand-300 dark:hover:border-brand-700">
        <div class="w-10 h-10 rounded-lg bg-brand-100 dark:bg-brand-900 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">Blog Posts</h2>
        <p class="text-sm text-slate-600 dark:text-slate-400">Create and manage blog posts.</p>
      </a>

      <!-- Analytics -->
      <div class="card p-6">
        <div class="w-10 h-10 rounded-lg bg-accent-100 dark:bg-accent-900 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">Analytics</h2>
        <p class="text-sm text-slate-600 dark:text-slate-400">View page views and engagement metrics.</p>
      </div>

      <!-- Messages -->
      <div class="card p-6">
        <div class="w-10 h-10 rounded-lg bg-purple-100 dark:bg-purple-900 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">Messages</h2>
        <p class="text-sm text-slate-600 dark:text-slate-400">View contact form submissions.</p>
      </div>
    </div>
  </div>
</BaseLayout>
