---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminPostEditor from '../../components/react/AdminPostEditor';
---

<BaseLayout title="New Post - Admin" description="Create a new blog post.">
  <div class="container-narrow py-12 sm:py-20">
    <header class="mb-8">
      <nav class="mb-4">
        <a href="/admin" class="text-sm text-brand-600 dark:text-brand-400 hover:underline">&larr; Back to Dashboard</a>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">New Blog Post</h1>
      <p class="text-slate-600 dark:text-slate-400 text-sm">
        Write your post using Markdown. Drafts are saved to the API and can be published later.
      </p>
    </header>

    <AdminPostEditor client:load />
  </div>
</BaseLayout>
