---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import { formatDate } from '../lib/utils';
import CopyButton from '../components/react/CopyButton';
import ViewCounter from '../components/react/ViewCounter';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    heroImage?: string;
    tags?: string[];
    readingTime?: string;
  };
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop() || '';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} ogType="article">
  <article class="container-narrow py-12 sm:py-20">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-slate-500 dark:text-slate-400">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-400">Blog</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-slate-900 dark:text-slate-100 truncate" aria-current="page">{frontmatter.title}</li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {frontmatter.tags?.map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-balance mb-4 text-slate-900 dark:text-white">
        {frontmatter.title}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{frontmatter.description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {formatDate(frontmatter.pubDate)}
        </time>
        {frontmatter.readingTime && (
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {frontmatter.readingTime}
          </span>
        )}
        <ViewCounter slug={slug} client:load />
        {frontmatter.updatedDate && (
          <span>Updated: {formatDate(frontmatter.updatedDate)}</span>
        )}
      </div>
    </header>

    {frontmatter.heroImage && (
      <img
        src={frontmatter.heroImage}
        alt={frontmatter.title}
        class="w-full rounded-xl mb-10 aspect-[2/1] object-cover"
        loading="eager"
      />
    )}

    <!-- TOC -->
    {headings.length > 2 && (
      <TOC headings={headings} />
    )}

    <!-- Content -->
    <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:scroll-mt-20 prose-a:decoration-brand-500 prose-a:underline-offset-2 prose-img:rounded-xl prose-pre:relative">
      <slot />
    </div>

    <!-- Post footer -->
    <footer class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-sm text-slate-500 dark:text-slate-400">Share this post</p>
          <div class="flex gap-3 mt-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-500 hover:text-brand-600 dark:hover:text-brand-400"
              aria-label="Share on Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-500 hover:text-brand-600 dark:hover:text-brand-400"
              aria-label="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
        <a href="/blog" class="btn-secondary text-sm">
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
          Back to all posts
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
