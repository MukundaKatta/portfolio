---
import BlogCard from './BlogCard.astro';
import { readingTime } from '../lib/utils';

interface Props {
  currentSlug: string;
  currentTags: string[];
  allPosts: any[];
  count?: number;
}

const { currentSlug, currentTags, allPosts, count = 3 } = Astro.props;

const related = allPosts
  .filter((post) => post.slug !== currentSlug)
  .map((post) => {
    const commonTags = post.data.tags?.filter((tag: string) => currentTags.includes(tag)) ?? [];
    return { ...post, relevance: commonTags.length };
  })
  .sort((a, b) => b.relevance - a.relevance)
  .slice(0, count);
---

{related.length > 0 && (
  <section class="mt-16" aria-label="Related posts">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Related Posts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.slug}
          readingTime={post.data.readingTime || readingTime(post.body || '')}
        />
      ))}
    </div>
  </section>
)}
