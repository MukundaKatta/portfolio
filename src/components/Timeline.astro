---
interface TimelineItem {
  year: string;
  title: string;
  description: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<div class="relative" role="list" aria-label="Career timeline">
  <!-- Vertical line -->
  <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-slate-700" aria-hidden="true"></div>

  {items.map((item, index) => (
    <div
      class="relative pl-12 pb-10 last:pb-0 animate-on-scroll"
      style={`animation-delay: ${index * 0.1}s`}
      role="listitem"
    >
      <!-- Dot -->
      <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-brand-500 border-2 border-white dark:border-slate-950 z-10" aria-hidden="true"></div>

      <div class="text-sm font-mono text-brand-600 dark:text-brand-400 mb-1">{item.year}</div>
      <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">{item.title}</h3>
      <p class="text-slate-600 dark:text-slate-400">{item.description}</p>
    </div>
  ))}
</div>
