---
interface Skill {
  name: string;
  level: number;
}

interface Props {
  skills: Skill[];
  size?: number;
}

const { skills, size = 300 } = Astro.props;
const center = size / 2;
const radius = (size / 2) - 40;
const angleStep = (2 * Math.PI) / skills.length;

function polarToCartesian(angle: number, r: number) {
  return {
    x: center + r * Math.cos(angle - Math.PI / 2),
    y: center + r * Math.sin(angle - Math.PI / 2),
  };
}

const gridLevels = [0.25, 0.5, 0.75, 1.0];

function getGridPolygon(level: number) {
  return skills
    .map((_, i) => {
      const { x, y } = polarToCartesian(i * angleStep, radius * level);
      return `${x},${y}`;
    })
    .join(' ');
}

const dataPoints = skills.map((skill, i) => {
  return polarToCartesian(i * angleStep, radius * (skill.level / 100));
});

const dataPath = dataPoints.map((p) => `${p.x},${p.y}`).join(' ');

const labelPositions = skills.map((skill, i) => {
  const { x, y } = polarToCartesian(i * angleStep, radius + 25);
  return { ...skill, x, y };
});
---

<div class="flex justify-center" role="img" aria-label="Skills radar chart">
  <svg viewBox={`0 0 ${size} ${size}`} class="w-full max-w-sm" xmlns="http://www.w3.org/2000/svg">
    <!-- Grid -->
    {gridLevels.map((level) => (
      <polygon
        points={getGridPolygon(level)}
        fill="none"
        stroke="currentColor"
        class="text-slate-200 dark:text-slate-700"
        stroke-width="1"
      />
    ))}

    <!-- Axes -->
    {skills.map((_, i) => {
      const { x, y } = polarToCartesian(i * angleStep, radius);
      return (
        <line
          x1={center}
          y1={center}
          x2={x}
          y2={y}
          stroke="currentColor"
          class="text-slate-200 dark:text-slate-700"
          stroke-width="1"
        />
      );
    })}

    <!-- Data polygon -->
    <polygon
      points={dataPath}
      class="fill-brand-500/20 stroke-brand-500"
      stroke-width="2"
    />

    <!-- Data points -->
    {dataPoints.map((p) => (
      <circle cx={p.x} cy={p.y} r="4" class="fill-brand-500" />
    ))}

    <!-- Labels -->
    {labelPositions.map((item) => (
      <text
        x={item.x}
        y={item.y}
        text-anchor="middle"
        dominant-baseline="middle"
        class="fill-slate-600 dark:fill-slate-400 text-xs font-medium"
        font-size="11"
      >
        {item.name}
      </text>
    ))}
  </svg>
</div>
